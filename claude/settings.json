{
  "model": "claude-fable-5[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "code-foundations@rtd": true,
    "oberskills@rtd": true,
    "design-for-ai@rtd": true,
    "react-native-foundations@rtd": true,
    "penman@rtd": true
  },
  "extraKnownMarketplaces": {
    "rtd": {
      "source": {
        "source": "github",
        "repo": "ryanthedev/rtd-claude-inn"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark"
}
